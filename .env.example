# AWS Configuration
# Credentials are loaded from environment or ~/.aws/credentials
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-2

# QuickBooks credentials are stored in AWS Secrets Manager (prod/qbo)
# Company ID is stored in SSM Parameter Store (/prod/qbo/company_id)
